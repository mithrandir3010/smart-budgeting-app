# ─── Database ────────────────────────────────────────────────────────────────
# Docker Compose ve Spring Boot tarafından ortak kullanılır
DB_NAME=smart_budget_db
DB_USERNAME=postgres
DB_PASSWORD=change_me_in_production
DB_PORT=5434
DB_URL=jdbc:postgresql://localhost:5434/smart_budget_db

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Production için: openssl rand -base64 32
JWT_SECRET=change_me_in_production_min_32_bytes_base64_encoded
JWT_EXPIRATION=86400000

# ─── OpenAI / LangChain4j (yalnızca PDF extraction) ─────────────────────────
OPENAI_API_KEY=sk-...

# ─── CORS ────────────────────────────────────────────────────────────────────
# Birden fazla origin için virgülle ayır:
# ALLOWED_ORIGINS=https://myapp.com,https://www.myapp.com
ALLOWED_ORIGINS=http://localhost:5173
